# ── App ──────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Upload limits ────────────────────────────
# Max file size in bytes (default 50 MB)
MAX_CONTENT_LENGTH=52428800

# ── Rate limiting ────────────────────────────
# Format: "<count> per <period>"  e.g. "20 per minute"
UPLOAD_RATE_LIMIT=20 per minute

# ── Gunicorn (used in Dockerfile CMD) ────────
WORKERS=2
TIMEOUT=120
